# Managed defaults for the Codex global Ralph skill.
#
# Ralph upstream still defaults to its own backend when used directly. The
# global Codex skill sources this file from its managed runtime so Ralph runs
# with Codex by default only in this installation path.
RALPH_GLOBAL_SKILL_BACKEND=codex
# Do not set a model here by default. Let Codex use the developer's current
# configured model unless the caller supplies --model or exports
# RALPH_GLOBAL_SKILL_MODEL for this invocation.
