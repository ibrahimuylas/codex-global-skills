# Managed defaults for the Codex global Ralph skill.
#
# Ralph upstream still defaults to its own backend when used directly. The
# global Codex skill sources this file from its managed runtime so Ralph runs
# with Codex by default only in this installation path.
RALPH_GLOBAL_SKILL_BACKEND=codex
# Ralph's upstream Codex backend can default to a model unavailable for
# ChatGPT-authenticated Codex sessions. The guarded global skill passes this
# model explicitly unless the caller supplies --model or the developer exports
# RALPH_GLOBAL_SKILL_MODEL.
RALPH_GLOBAL_SKILL_MODEL="${RALPH_GLOBAL_SKILL_MODEL:-gpt-5.6-sol}"
